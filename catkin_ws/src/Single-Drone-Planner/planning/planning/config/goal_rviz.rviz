Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /goalState1
        - /Odom1/Shape1
        - /cam_pose1/Shape1
        - /Mapping1
        - /Mapping1/pcl_env_gt1/Autocompute Value Bounds1
        - /Mapping1/pcl_tgt_gt1
        - /Mapping1/pcl_tgt_gt1/Autocompute Value Bounds1
        - /Planning1
        - /Planning1/back_end1
        - /Planning1/back_end1/back_end_debug1/mid_q1
        - /RC_SDF1/Map_SDF_Slice1
        - /RC_SDF1/Map_SDF_Slice1/box01
        - /end_pose_ref1/Shape1
        - /end_pose_est1/Shape1
        - /yolo1
        - /yolo1/mask1
        - /yolo1/cam_pose1
        - /yolo1/rgb1
        - /Pose1
      Splitter Ratio: 0.7230392098426819
    Tree Height: 192
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: tgt_occ_gs
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
