<launch>

<!-- Patrick -->
  <arg name="init_x_" default="0.0"/>
  <arg name="init_y_" default="0.0"/>
  <arg name="init_z_" default="1.0"/>
  <arg name="odom_topic_" default="/TABV/odometry_sensor1/odometry"/>

  <group ns="drone0">

    <!-- <node pkg="poscmd_2_odom" name="drone_poscmd_2_odom" type="poscmd_2_odom" output="screen">
          <param name="init_x" value="$(arg init_x_)"/>
          <param name="init_y" value="$(arg init_y_)"/>
          <param name="init_z" value="$(arg init_z_)"/>
          <remap from="~command" to="/position_cmd"/>
          <remap from="~odometry" to="$(arg odom_topic_)"/>
    </node> -->

    <node pkg="odom_visualization" name="odom_visualization" type="odom_visualization" output="screen">
      <rosparam command="load" file="$(find ch_rc_sdf)/config/params.yaml" />
      <remap from="~odom" to="$(arg odom_topic_)" />
      <param name="robot_scale" value="1.0"/>
    </node>
    
    <node pkg="planning" name="planning" type="planning" output="screen">

      <rosparam command="load" file="$(find ch_rc_sdf)/config/params.yaml" />

      <remap from="/drone0/odom" to="$(arg odom_topic_)"/>
      <remap from="/drone0/gridmap_inflate" to="gridmap_inflate"/>
      <remap from="/drone0/target" to="/target/odom"/>
      <remap from="/drone0/triger" to="/triger"/>
      <remap from="/drone0/goal" to="/move_base_simple/goal"/>
      <remap from="/drone0/land_triger" to="/land_triger"/>
      <remap from="/drone0/joy" to="/joy_main"/>

      <remap from ="/map_ros/pose"   to = "$(arg odom_topic_)"/> 

      <!-- pcl_rendered -->
      <!-- <remap from ="/map_ros/depth" to = "/drone0/depth"/> -->
      <!-- gazebo -->
      <remap from ="/map_ros/depth" to = "/TABV/camera_base/depth/image_raw"/>

      <remap from ="/map_ros/cloud" to="/sync_pcl"/>

      <param name="sdf_map/resolution"      value="0.1" /> 

      <param name="sdf_map/ground_height"        value="-1.0"/>
      <param name="sdf_map/map_size_x"   value="20.0" /> 
      <param name="sdf_map/map_size_y"   value="10.0" />
      <param name="sdf_map/map_size_z"   value="6.0" /> 

      <param name="sdf_map/obstacles_inflation"     value="0.099" /> 
      <param name="sdf_map/local_bound_inflate"    value="0.5"/>
      <param name="sdf_map/local_map_margin" value="50"/>
      <param name="sdf_map/default_dist"        value="5.0"/>
      
      <param name="sdf_map/p_hit"  value="0.65"/>
      <param name="sdf_map/p_miss" value="0.35"/>
      <param name="sdf_map/p_min"  value="0.12"/>
      <param name="sdf_map/p_max"  value="0.90"/>
      <param name="sdf_map/p_occ"  value="0.80"/>
      <param name="sdf_map/min_ray_length" value="0.2"/>
      <!-- 需要比depth_filter_maxdist长一点 -->
      <param name="sdf_map/max_ray_length" value="3.0"/>
      <param name="sdf_map/virtual_ceil_height"   value="-10"/>
      <param name="sdf_map/optimistic" value="true" type="bool"/>
      <param name="sdf_map/signed_dist" value="true" type="bool"/>

      <param name="sdf_map/aabb_x" value="1.0" type="double"/>
      <param name="sdf_map/aabb_y" value="1.0" type="double"/>
      <param name="sdf_map/aabb_z" value="0.5" type="double"/>

    <!-- # 0 RVIZ_GOAL, -->
    <!-- # 1 MANNUAL_SEQUENCE, -->
    <!-- # 1 PRE_SEQUENCE, -->
      <!-- <param name="sdf_map/goal_method" value="1"/> -->
      <param name="sdf_map/goal_method" value="0"/>


      <param name="map_ros/fx" value="240"/>
      <param name="map_ros/fy" value="240"/>
      <param name="map_ros/cx" value="320"/>
      <param name="map_ros/cy" value="240"/>

      <param name="map_ros/depth_filter_maxdist"   value="3.0"/>
      <param name="map_ros/depth_filter_mindist"   value="0.2"/>
      <param name="map_ros/depth_filter_margin"    value="2"/>
      <param name="map_ros/k_depth_scaling_factor" value="1.0"/>
      <param name="map_ros/skip_pixel" value="2"/>
      <param name="map_ros/esdf_slice_height" value="0.7"/>
      <param name="map_ros/visualization_truncate_height"   value="3.0"/>
      <param name="map_ros/visualization_truncate_low"   value="0.09"/>
      <param name="map_ros/show_occ_time"  value="false"/>
      <param name="map_ros/show_esdf_time" value="false"/>
      <param name="map_ros/show_all_map" value="true"/>
      <param name="map_ros/frame_id"      value="world"/>

      <param name="map_ros/gs_gather_radius" value="3.0"/>
      <param name="map_ros/input_cam_pose" value="true"/>

    </node>


  </group>
</launch>

