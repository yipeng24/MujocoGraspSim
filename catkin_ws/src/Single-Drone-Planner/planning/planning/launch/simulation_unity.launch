  <arg name="init_z_" default="7.0"/>


  <!-- <node pkg="colored_pcl_generator" name="point_cloud_generator" type="colored_pcl_generator" output="screen">
        <param name="magic_number" value="0.053"/>
        <param name="a_cor" value="0.0"/>
        <param name="b_cor" value="1.5"/>
