<launch>
  <!--
    yoloe_seg.launch
    ================
    单独启动 YOLOE 分割节点（通常由 yoloe_pipeline.launch 调用）
  -->
  <arg name="config_path"
       default="$(find yoloe_seg)/cfg/config.yaml"/>

  <node pkg="yoloe_seg" type="yoloe_seg_node.py"
        name="yoloe_seg" output="screen">
    <param name="config_path" value="$(arg config_path)"/>
  </node>
</launch>
