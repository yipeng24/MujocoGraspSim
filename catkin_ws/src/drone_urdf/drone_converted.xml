<mujoco model="drone_urdf">
  <compiler angle="radian" meshdir="meshes" />
  <asset>
    <mesh name="base_link" content_type="model/stl" file="base_link.STL" />
    <mesh name="arm_link_pitch" content_type="model/stl" file="arm_link_pitch.STL" />
    <mesh name="arm_link_pitch2" content_type="model/stl" file="arm_link_pitch2.STL" />
    <mesh name="arm_link_roll" content_type="model/stl" file="arm_link_roll.STL" />
    <mesh name="arm_link_right_finger" content_type="model/stl" file="arm_link_right_finger.STL" />
    <mesh name="arm_link_left_finger" content_type="model/stl" file="arm_link_left_finger.STL" />
    <mesh name="rotor_0" content_type="model/stl" file="rotor_0.STL" />
    <mesh name="rotor_1" content_type="model/stl" file="rotor_1.STL" />
    <mesh name="rotor_2" content_type="model/stl" file="rotor_2.STL" />
    <mesh name="rotor_3" content_type="model/stl" file="rotor_3.STL" />
    </asset>
  <worldbody>
    <body name="base_link" pos="0 0 0" quat="1 0 0 0">
      <freejoint name="base_free" />
      <geom type="mesh" rgba="0 0 0 1" mesh="base_link" />

      <!-- 前视深度相机：机头(+X)前方 6cm，朝 +X 方向看，fovy=60° (类 RealSense D435) -->
      <camera name="depth_cam"
              pos="0.06 0 -0.02"
              xyaxes="0 -1 0 0 0 1"
              fovy="60"/>

      <body name="arm_pitch_link" pos="-0.009 -0.0096 -0.108565">
        <inertial pos="-0.0398454 0.0119006 -0.00382043" quat="-0.000136126 0.576951 -0.00019689 0.816779" mass="0.278848" diaginertia="0.000286784 0.000276262 0.000197652" />
        <joint name="arm_pitch_joint" pos="0 0 0" axis="0 1 0" range="0 1.5708" actuatorfrcrange="-5 5" />
        <geom type="mesh" rgba="0.752941 0.752941 0.752941 1" mesh="arm_link_pitch" />
        <body name="arm_pitch2_link" pos="0.12175 0.00855 0">
          <inertial pos="-0.0235169 4.18533e-06 -0.00768195" quat="0.999822 -0.000819779 0.0188322 -0.00049632" mass="0.0210875" diaginertia="6.40168e-06 4.08924e-06 3.21556e-06" />
          <joint name="arm_pitch2_joint" pos="0 0 0" axis="0 1 0" range="-1.5708 1.5708" actuatorfrcrange="-5 5" />
          <geom type="mesh" rgba="0.752941 0.752941 0.752941 1" mesh="arm_link_pitch2" />

          <!-- 腕部相机：挂在 arm_pitch2_link，位于手指正上方，朝臂延伸方向 (+X) 看 -->
          <camera name="wrist_cam"
                  pos="0.025 0 0.04"
                  xyaxes="0 -1 0 0 0 1"/>

          <body name="arm_roll_link" pos="-0.01275 0 0">
            <inertial pos="0.0214596 0 0" quat="0.707107 0.707107 0 0" mass="0.0484342" diaginertia="1.16041e-05 1.15999e-05 1.03955e-05" />
            <joint name="arm_roll_joint" pos="0 0 0" axis="1 0 0" range="-1.5708 1.5708" actuatorfrcrange="-1 1" />
            <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="arm_link_roll" />
            <!-- gripper_frame: 夹爪中心参考点，位于 arm_roll_link +X 方向 7cm 处 -->
            <site name="gripper_frame" pos="0.07 0 0" size="0.004" rgba="1 0.3 0 1"/>
            <body name="arm_right_finger_link" pos="0.041 0 0" quat="0 -1 0 0">
              <inertial pos="0.0266573 0.00731144 0" quat="0.531927 0.531927 0.465891 0.465891" mass="0.013758" diaginertia="4.72941e-06 4.43352e-06 6.94702e-07" />
              <joint name="arm_right_finger_joint" pos="0 0 0" axis="0 1 0" type="slide" range="-1.5708 1.5708" actuatorfrcrange="-1 1" />
              <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="arm_link_right_finger" />
              </body>
            <body name="arm_left_finger_link" pos="0.041 0 0">
              <inertial pos="0.0266573 0.00731144 0" quat="0.531927 0.531927 0.465891 0.465891" mass="0.013758" diaginertia="4.72941e-06 4.43352e-06 6.94702e-07" />
              <joint name="arm_left_finger_joint" pos="0 0 0" axis="0 -1 0" type="slide" range="-1.5708 1.5708" actuatorfrcrange="-1 1" />
              <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="arm_link_left_finger" />
              </body>
            </body>
          </body> 
        </body>
      <body name="rotor0_link" pos="0.123744 0.123744 0.0211606">
        <inertial pos="4.10029e-07 2.17598e-07 0.00394569" quat="0.60751 0.361842 -0.607513 0.361843" mass="0.00513322" diaginertia="9.75117e-06 4.89108e-06 4.89084e-06" />
        <joint name="rotor0_joint" type="hinge" pos="0 0 0" axis="0 0 1" />
        <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="rotor_0" />
        </body>
      <body name="rotor1_link" pos="-0.123744 0.123744 0.0212">
        <inertial pos="-1.75373e-07 8.47259e-09 0.00390633" quat="0.349938 0.614445 -0.349938 0.614445" mass="0.00513323" diaginertia="9.75113e-06 4.89097e-06 4.89091e-06" />
        <joint name="rotor1_joint" type="hinge" pos="0 0 0" axis="0 0 1" />
        <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="rotor_1" />
        </body>
      <body name="rotor2_link" pos="-0.123744 -0.123744 0.0212">
        <inertial pos="-4.10029e-07 -2.17598e-07 0.00390632" quat="0.607513 0.361843 -0.60751 0.361842" mass="0.00513322" diaginertia="9.75117e-06 4.89108e-06 4.89084e-06" />
        <joint name="rotor2_joint" type="hinge" pos="0 0 0" axis="0 0 1" />
        <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="rotor_2" />
        </body>
      <body name="rotor3_link" pos="0.123744 -0.123744 0.0212">
        <inertial pos="1.75373e-07 -8.47259e-09 0.00390633" quat="0.349938 0.614445 -0.349938 0.614445" mass="0.00513323" diaginertia="9.75113e-06 4.89097e-06 4.89091e-06" />
        <joint name="rotor3_joint" type="hinge" pos="0 0 0" axis="0 0 1" />
        <geom type="mesh" rgba="0.792157 0.819608 0.933333 1" mesh="rotor_3" />
        </body>
      <site name="imu_site" pos="0 0 0" size="0.005" />
      </body>
    </worldbody>
  </mujoco>
